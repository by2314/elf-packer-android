<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Success banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅"
                android:textSize="48sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="加固完成"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Result details card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Input file -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="0.4"
                        android:text="@string/label_input_name"
                        android:textSize="13sp" android:textColor="#757575" />
                    <TextView
                        android:id="@+id/tv_input_name"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:textSize="14sp" android:textColor="@color/colorOnSurface"
                        android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/colorDivider" android:layout_marginBottom="12dp" />

                <!-- Packer type -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="0.4"
                        android:text="@string/label_packer_type"
                        android:textSize="13sp" android:textColor="#757575" />
                    <TextView
                        android:id="@+id/tv_packer_type"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:textSize="14sp" android:textColor="@color/colorPrimary"
                        android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/colorDivider" android:layout_marginBottom="12dp" />

                <!-- Original size -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="0.4"
                        android:text="@string/label_original_size"
                        android:textSize="13sp" android:textColor="#757575" />
                    <TextView
                        android:id="@+id/tv_original_size"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:textSize="14sp" android:textColor="@color/colorOnSurface" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/colorDivider" android:layout_marginBottom="12dp" />

                <!-- Packed size -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="0.4"
                        android:text="@string/label_packed_size"
                        android:textSize="13sp" android:textColor="#757575" />
                    <TextView
                        android:id="@+id/tv_packed_size"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:textSize="14sp" android:textColor="@color/colorOnSurface" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/colorDivider" android:layout_marginBottom="12dp" />

                <!-- Ratio -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="0.4"
                        android:text="@string/label_ratio"
                        android:textSize="13sp" android:textColor="#757575" />
                    <TextView
                        android:id="@+id/tv_ratio"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:textSize="14sp" android:textColor="@color/colorSecondaryVariant"
                        android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/colorDivider" android:layout_marginBottom="12dp" />

                <!-- Output path -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="0.4"
                        android:text="@string/label_output_path"
                        android:textSize="13sp" android:textColor="#757575" />
                    <TextView
                        android:id="@+id/tv_output_path"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:textSize="12sp" android:textColor="#424242"
                        android:singleLine="false" android:maxLines="4" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Action buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="10dp"
            android:text="@string/btn_share"
            android:textSize="15sp"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_home"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_home"
            android:textSize="15sp"
            app:cornerRadius="8dp" />

    </LinearLayout>
</ScrollView>
